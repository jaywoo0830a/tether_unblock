#!/sbin/sh
#
# Tether Unblock — module installer
# Supports: Magisk v20.4+, KernelSU, APatch
#
# This is the standard Magisk module_installer.sh with added
# fallback paths for KernelSU.

#################
# Initialization
#################

umask 022

# echo before loading util_functions
ui_print() { echo "$1"; }

require_new_magisk() {
  ui_print "*********************************************"
  ui_print " Tether Unblock requires:"
  ui_print "   - Magisk v20.4+  (or)"
  ui_print "   - KernelSU        (or)"
  ui_print "   - APatch"
  ui_print "*********************************************"
  exit 1
}

#########################
# Load util_functions.sh
#########################

OUTFD=$2
ZIPFILE=$3

mount /data 2>/dev/null

# Try Magisk path first, then KernelSU, then APatch
if [ -f /data/adb/magisk/util_functions.sh ]; then
  . /data/adb/magisk/util_functions.sh
elif [ -f /data/adb/ksu/bin/util_functions.sh ]; then
  . /data/adb/ksu/bin/util_functions.sh
elif [ -f /data/adb/ap/bin/util_functions.sh ]; then
  . /data/adb/ap/bin/util_functions.sh
else
  require_new_magisk
fi

[ "${MAGISK_VER_CODE:-0}" -lt 20400 ] && require_new_magisk

install_module
exit 0

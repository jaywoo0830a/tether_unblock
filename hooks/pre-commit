#!/usr/bin/env sh
# Pre-commit hook for Magisk module development
# Install with: make setup

ERRORS=0

# --- ShellCheck on staged .sh files ---
STAGED_SH=$(git diff --cached --name-only --diff-filter=ACM | grep '\.sh$')
if [ -n "${STAGED_SH}" ]; then
    if command -v shellcheck >/dev/null 2>&1; then
        SHELLCHECK_FAIL=0
        for f in ${STAGED_SH}; do
            if ! git show ":${f}" | shellcheck -s sh -; then
                SHELLCHECK_FAIL=1
            fi
        done
        if [ "${SHELLCHECK_FAIL}" -eq 0 ]; then
            printf "[OK]   ShellCheck passed\n"
        else
            printf "[FAIL] ShellCheck found issues\n"
            ERRORS=$((ERRORS + 1))
        fi
    else
        printf "[SKIP] shellcheck not installed\n"
    fi
fi

# --- Version consistency check ---
STAGED=$(git diff --cached --name-only)
if echo "${STAGED}" | grep -qE '^(module\.prop|update\.json)$'; then
    if command -v python3 >/dev/null 2>&1; then
        PROP_VER=$(git show :module.prop | grep '^version=' | cut -d= -f2)
        PROP_VC=$(git show :module.prop | grep '^versionCode=' | cut -d= -f2)
        JSON_VER=$(git show :update.json | python3 -c "import json,sys; print(json.load(sys.stdin)['version'])")
        JSON_VC=$(git show :update.json | python3 -c "import json,sys; print(json.load(sys.stdin)['versionCode'])")

        if [ "${PROP_VER}" = "${JSON_VER}" ] && [ "${PROP_VC}" = "${JSON_VC}" ]; then
            printf "[OK]   Version consistency: %s (%s)\n" "${PROP_VER}" "${PROP_VC}"
        else
            printf "[FAIL] Version mismatch: module.prop %s (%s) != update.json %s (%s)\n" \
                "${PROP_VER}" "${PROP_VC}" "${JSON_VER}" "${JSON_VC}"
            ERRORS=$((ERRORS + 1))
        fi
    else
        printf "[SKIP] python3 not available, cannot check version consistency\n"
    fi
fi

# --- updater-script content check ---
if echo "${STAGED}" | grep -q '^META-INF/com/google/android/updater-script$'; then
    CONTENT=$(git show :META-INF/com/google/android/updater-script)
    if [ "${CONTENT}" = "#MAGISK" ]; then
        printf "[OK]   updater-script contains '#MAGISK'\n"
    else
        printf "[FAIL] updater-script must contain exactly '#MAGISK'\n"
        ERRORS=$((ERRORS + 1))
    fi
fi

if [ "${ERRORS}" -gt 0 ]; then
    printf "\nPre-commit hook failed with %d error(s)\n" "${ERRORS}"
    exit 1
fi

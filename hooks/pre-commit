#!/usr/bin/env sh
# Pre-commit hook for Magisk module development
# Install with: make setup

ERRORS=0

# --- ShellCheck on staged .sh files ---
STAGED_SH=$(git diff --cached --name-only --diff-filter=ACM | grep '\.sh$')
if [ -n "${STAGED_SH}" ]; then
    if command -v shellcheck >/dev/null 2>&1; then
        SHELLCHECK_FAIL=0
        for f in ${STAGED_SH}; do
            if ! git show ":${f}" | shellcheck -s sh -; then
                SHELLCHECK_FAIL=1
            fi
        done
        if [ "${SHELLCHECK_FAIL}" -eq 0 ]; then
            printf "[OK]   ShellCheck passed\n"
        else
            printf "[FAIL] ShellCheck found issues\n"
            ERRORS=$((ERRORS + 1))
        fi
    else
        printf "[SKIP] shellcheck not installed\n"
    fi
fi

# --- Version consistency check ---
STAGED=$(git diff --cached --name-only)
if echo "${STAGED}" | grep -qE '^(module\.prop|update\.json)$'; then
    if command -v python3 >/dev/null 2>&1; then
        PROP_VER=$(git show :module.prop | grep '^version=' | cut -d= -f2)
        PROP_VC=$(git show :module.prop | grep '^versionCode=' | cut -d= -f2)
        JSON_VER=$(git show :update.json | python3 -c "import json,sys; print(json.load(sys.stdin)['version'])")
        JSON_VC=$(git show :update.json | python3 -c "import json,sys; print(json.load(sys.stdin)['versionCode'])")

        if [ "${PROP_VER}" = "${JSON_VER}" ] && [ "${PROP_VC}" = "${JSON_VC}" ]; then
            printf "[OK]   Version consistency: %s (%s)\n" "${PROP_VER}" "${PROP_VC}"
        else
            printf "[FAIL] Version mismatch: module.prop %s (%s) != update.json %s (%s)\n" \
                "${PROP_VER}" "${PROP_VC}" "${JSON_VER}" "${JSON_VC}"
            ERRORS=$((ERRORS + 1))
        fi
    else
        printf "[SKIP] python3 not available, cannot check version consistency\n"
    fi
fi

# --- updater-script content check ---
if echo "${STAGED}" | grep -q '^META-INF/com/google/android/updater-script$'; then
    CONTENT=$(git show :META-INF/com/google/android/updater-script)
    if [ "${CONTENT}" = "#MAGISK" ]; then
        printf "[OK]   updater-script contains '#MAGISK'\n"
    else
        printf "[FAIL] updater-script must contain exactly '#MAGISK'\n"
        ERRORS=$((ERRORS + 1))
    fi
fi

# --- common.sh sourcing check (service.sh, uninstall.sh) ---
for consumer in service.sh uninstall.sh; do
    if echo "${STAGED}" | grep -q "^${consumer}\$"; then
        if git show ":${consumer}" | grep -q 'common\.sh'; then
            printf "[OK]   %s sources common.sh\n" "${consumer}"
        else
            printf "[FAIL] %s must source common.sh\n" "${consumer}"
            ERRORS=$((ERRORS + 1))
        fi
    fi
done

# --- DRY check: no duplicate function definitions ---
# Functions defined in common.sh must not be redefined in service.sh or
# uninstall.sh (except log() which uninstall.sh intentionally overrides).
if echo "${STAGED}" | grep -qE '^(common\.sh|service\.sh|uninstall\.sh)$'; then
    COMMON_FUNCS=$(git show :common.sh | grep '^[a-z_]*()' | sed 's/().*//' | grep -v '^log$')
    for consumer in service.sh uninstall.sh; do
        for fn in ${COMMON_FUNCS}; do
            if git show ":${consumer}" 2>/dev/null | grep -q "^${fn}()"; then
                printf "[FAIL] %s redefines %s() — should use common.sh version\n" \
                    "${consumer}" "${fn}"
                ERRORS=$((ERRORS + 1))
            fi
        done
    done
    if [ "${ERRORS}" -eq "${ERRORS_BEFORE_DRY:-0}" ]; then
        printf "[OK]   No duplicate function definitions (DRY)\n"
    fi
    ERRORS_BEFORE_DRY=${ERRORS}
fi

# --- shebang & indentation convention ---
STAGED_SH_ALL=$(echo "${STAGED}" | grep '\.sh$')
for f in ${STAGED_SH_ALL}; do
    # .sh files must have a shebang
    if ! git show ":${f}" | head -n1 | grep -q '^#!/'; then
        printf "[FAIL] %s missing shebang (first line must start with #!)\n" "${f}"
        ERRORS=$((ERRORS + 1))
    fi
    # Use tabs for indentation, not spaces (except comments/heredocs)
    if git show ":${f}" | grep -nP '^    [a-zA-Z]' >/dev/null 2>&1; then
        printf "[FAIL] %s uses spaces for indentation — please use tabs\n" "${f}"
        ERRORS=$((ERRORS + 1))
    fi
done

if [ "${ERRORS}" -gt 0 ]; then
    printf "\nPre-commit hook failed with %d error(s)\n" "${ERRORS}"
    exit 1
fi
